# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the SEALED (encrypted) bundled credentials ship to the agent via git.
# Only the ciphertext is committed; plaintext .env stays ignored above.
!agent-bundle/src/.env.enc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python bytecode (inside agent-bundle)
__pycache__/
*.pyc
*.pyo
agent-update.json

.agentvenv/
playwright-report/
test-results/
/blob-report/
.playwright/
.pytest_cache/

# Desktop app clone — local parity reference only. Never tracked in this repo
# (it carries its own Git LFS objects that would break pushes here).
desktop-reference/
agent-bundle/.venv/

# Local-only in-sandbox test rig (mock agent launcher). Never committed.
.localtest/

# npm lockfile — this project uses pnpm exclusively.
package-lock.json

.vercel

# AI/IDE workspace artifacts (Repowise, Claude, VS Code)
.repowise/
.repowise-workspace/
.repowise-workspace.yaml
.claude/
!.claude/agents/
.mcp.json
.vscode/
.augment-session.json
centrality_cache.pkl
duplication_cache.pkl

# Internal documentation (not for distribution)
GenAI Documentation.pdf

# Workspace artifacts (monorepo root level only)
pnpm-workspace.yaml
testing-toolkit-enhanced.zip
